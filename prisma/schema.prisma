generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  // NO URL HERE! Prisma 7 handles it via prisma.config.ts
}

// --------------------------------------
// 1. KHAALICLASS USER ROLES & AUTH
// --------------------------------------

enum Role {
  STUDENT
  CR
  ADMIN
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String // Text is SQL-specific, use String for MongoDB
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(STUDENT) // Fixed Enum mismatch
  crRequested   Boolean   @default(false)
  trustScore    Int       @default(100) 
  
  // Relations mapped for NextAuth and AuditLogs
  accounts      Account[]
  sessions      Session[]
  roomOverrides RoomOverride[]
  auditLogs     AuditLog[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId // Required for MongoDB
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --------------------------------------
// 2. KHAALICLASS APP DATA MODELS
// --------------------------------------

model Room {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  name      String         @unique
  building  String
  latitude  Float
  longitude Float
  capacity  Int
  floor     String
  status    String         @default("AVAILABLE") 
  reports   Report[]
  schedules Schedule[]
  overrides RoomOverride[] 
  updatedAt DateTime       @updatedAt
}

model Schedule {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId    String   @db.ObjectId
  room      Room     @relation(fields: [roomId], references: [id])
  dayOfWeek Int      
  startTime String   
  endTime   String   
  course    String
}

model Report {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId           String   @db.ObjectId
  room             Room     @relation(fields: [roomId], references: [id])
  userId           String   @db.ObjectId
  status           String   
  trusted          Boolean  @default(false)
  timestamp        DateTime @default(now())
  moderationStatus String   @default("PENDING") 
  rejectedReason   String?  
}

// --------------------------------------
// 3. KHAALICLASS MANAGEMENT MODELS
// --------------------------------------

model RoomOverride {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId    String   @db.ObjectId
  room      Room     @relation(fields: [roomId], references: [id])
  date      DateTime 
  startTime String   
  endTime   String   
  status    String   
  reason    String?  
  crId      String   @db.ObjectId
  user      User     @relation(fields: [crId], references: [id])
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  action    String   
  details   String   
  timestamp DateTime @default(now())
}

// ------------------------------------------------------
// 4. SHADOW FILTER & CR LOGS
// ------------------------------------------------------

model CRAuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userName    String   
  roomName    String   
  action      String   
  timestamp   DateTime @default(now())
}

model StudentSuggestion {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  roomName        String   
  reportedStatus  String   
  distanceMeters  Float    
  isValidated     Boolean  
  userName        String?  @default("Anonymous Student")
  timestamp       DateTime @default(now())
}